action_priority_list_t* precombat = get_action_priority_list( "precombat" );
action_priority_list_t* def = get_action_priority_list( "default" );
action_priority_list_t* aoe = get_action_priority_list( "aoe" );
action_priority_list_t* ec_st = get_action_priority_list( "ec_st" );
action_priority_list_t* kotg_st = get_action_priority_list( "kotg_st" );

precombat->add_action( "variable,name=no_cd_talent,value=!talent.celestial_alignment&!talent.incarnation_chosen_of_elune|druid.no_cds","Executed before combat begins. Accepts non-harmful actions only." );
precombat->add_action( "variable,name=opener,op=set,value=1" );
precombat->add_action( "variable,name=ec,op=set,value=1,if=talent.boundless_moonlight" );
precombat->add_action( "variable,name=on_use_trinket,value=0" );
precombat->add_action( "variable,name=on_use_trinket,op=add,value=trinket.1.has_use_buff" );
precombat->add_action( "variable,name=on_use_trinket,op=add,value=(trinket.2.has_use_buff)*2" );
precombat->add_action( "variable,name=prio,op=set,value=0" );
precombat->add_action( "variable,name=inc_charge,op=set,value=0" );
precombat->add_action( "moonkin_form" );
precombat->add_action( "wrath","Pre-Cast" );
precombat->add_action( "wrath" );
precombat->add_action( "wrath,if=talent.dream_surge&enemies=1" );
precombat->add_action( "starfire,if=hero_tree.elunes_chosen|enemies>1" );

def->add_action( "use_items,if=buff.ca_inc.up&(buff.harmony_of_the_grove.up|!talent.dream_surge)|fight_remains<cooldown.ca_inc.remains","Items, Racials & PI" );
def->add_action( "potion,if=buff.harmony_of_the_grove.up&!variable.ec|buff.ca_inc.up&variable.ec|variable.opener&prev_gcd.1.solar_eclipse|fight_remains<=30" );
def->add_action( "berserking,if=buff.ca_inc.up&(buff.harmony_of_the_grove.up|!talent.dream_surge)|fight_remains<cooldown.ca_inc.remains" );
def->add_action( "invoke_external_buff,name=power_infusion,if=buff.ca_inc.up" );
def->add_action( "variable,name=inc_charge,op=set,value=1,if=cooldown.ca_inc.charges_fractional<1","Variables Definition" );
def->add_action( "variable,name=opener,op=set,value=0,if=buff.ca_inc.up" );
def->add_action( "variable,name=eclipse_down,value=!buff.eclipse_lunar.up&!buff.eclipse_solar.up" );
def->add_action( "variable,name=cd_window,value=cooldown.force_of_nature.remains>15|cooldown.ca_inc.remains<44" );
def->add_action( "variable,name=cd_window_narrow,value=cooldown.force_of_nature.remains>30|cooldown.ca_inc.remains>10&cooldown.ca_inc.remains<20" );
def->add_action( "variable,name=no_weaver_procs,value=!buff.touch_the_cosmos.react&!buff.starweavers_warp.react" );
def->add_action( "variable,name=ca_soon,value=cooldown.ca_inc.remains<3|cooldown.ca_inc.charges_fractional>1" );
def->add_action( "run_action_list,name=ec_st,if=hero_tree.elunes_chosen&spell_targets=1","Run the APL" );
def->add_action( "run_action_list,name=kotg_st,if=spell_targets=1" );
def->add_action( "run_action_list,name=aoe,if=spell_targets>1" );

aoe->add_action( "celestial_alignment,if=prev_gcd.1.force_of_nature&!variable.ec|variable.ec&prev_gcd.1.fury_of_elune&buff.ca_inc.down&buff.ascendant_stars.down&(trinket.1.cooldown.remains>60|trinket.1.cooldown.ready|fight_remains<trinket.1.cooldown.remains|trinket.2.cooldown.remains>60|trinket.2.cooldown.ready|fight_remains<trinket.2.cooldown.remains)|fight_remains<20","Cooldowns" );
aoe->add_action( "moonfire,target_if=remains<2|refreshable&variable.eclipse_down","Dots" );
aoe->add_action( "sunfire,target_if=remains<2|refreshable&variable.eclipse_down" );
aoe->add_action( "fury_of_elune,if=variable.opener&!variable.eclipse_down&buff.ascendant_stars.down|!variable.opener&(!variable.ec&(buff.harmony_of_the_grove.up|cooldown.force_of_nature.remains<gcd.max|talent.radiant_moonlight&cooldown.force_of_nature.remains>20)|variable.ec&buff.ascendant_stars.down&(cooldown.ca_inc.ready&trinket.1.cooldown.ready|cooldown.ca_inc.remains>10|trinket.1.cooldown.remains>10))","Fury of Elune" );
aoe->add_action( "solar_eclipse,if=variable.opener&cooldown.eclipse.charges_fractional=2|!variable.opener&cooldown.solar_eclipse.charges_fractional>1.5&variable.cd_window|cooldown.solar_eclipse.ready&variable.cd_window_narrow|fight_remains<15","Enter Solar" );
aoe->add_action( "lunar_eclipse,if=!variable.prio&spell_targets>2&!variable.ec&(variable.opener&cooldown.eclipse.charges_fractional=2|!variable.opener&cooldown.lunar_eclipse.charges_fractional>1.5&variable.cd_window|cooldown.lunar_eclipse.ready&variable.cd_window_narrow)|variable.ec&(variable.opener|cooldown.ca_inc.full_recharge_time>15)|fight_remains<15","Enter Lunar" );
aoe->add_action( "convoke_the_spirits,if=buff.ca_inc.up&astral_power<40|cooldown.ca_inc.remains>50&buff.harmony_of_the_grove.up&buff.ca_inc.down","Convoke" );
aoe->add_action( "wrath,if=!talent.convoke_the_spirits&spell_targets<3&buff.ascendant_stars.down&(variable.opener&astral_power<50|!variable.opener&astral_power<80&variable.no_weaver_procs&cooldown.force_of_nature.remains<15)","Cast Wrath if Going Solar" );
aoe->add_action( "sunfire,target_if=variable.opener&buff.ascendant_stars.down|!variable.opener&dot.sunfire.remains<10&variable.ca_soon&cooldown.force_of_nature.remains<3,line_cd=10","Cast Sunfire Before Cooldowns" );
aoe->add_action( "force_of_nature,if=!variable.opener|buff.ascendant_stars.down","Treants" );
aoe->add_action( "starfall,if=astral_power>80|!variable.eclipse_down|!buff.starweavers_weft.react","Spenders" );
aoe->add_action( "starsurge,if=buff.starweavers_weft.react" );
aoe->add_action( "starfire,if=buff.ascendant_fires.up&buff.eclipse_lunar.up","Builders" );
aoe->add_action( "new_moon,if=astral_power.deficit>energize_amount" );
aoe->add_action( "half_moon,if=astral_power.deficit>energize_amount" );
aoe->add_action( "full_moon,if=astral_power.deficit>energize_amount" );
aoe->add_action( "wild_mushroom,if=buff.eclipse_solar.up|cooldown.wild_mushroom.full_recharge_time<cooldown.ca_inc.remains" );
aoe->add_action( "starfire,if=variable.ec|variable.eclipse_down&spell_targets.starfire>6|buff.eclipse_lunar.up&(spell_targets.starfire>2&buff.ca_inc.up|spell_targets.starfire<=2&!buff.ca_inc.up)" );
aoe->add_action( "wrath" );

ec_st->add_action( "celestial_alignment,if=buff.ca_inc.down&cooldown.eclipse.charges_fractional<1.5&buff.ascendant_stars.down","Cooldowns" );
ec_st->add_action( "moonfire,target_if=remains<2|refreshable&variable.eclipse_down","Dots" );
ec_st->add_action( "sunfire,target_if=remains<2|refreshable&variable.eclipse_down" );
ec_st->add_action( "convoke_the_spirits,if=buff.ca_inc.up&astral_power<40|cooldown.ca_inc.remains>50|fight_remains<30","Convoke" );
ec_st->add_action( "lunar_eclipse,if=cooldown.ca_inc.full_recharge_time>15|variable.opener","Enter Lunar" );
ec_st->add_action( "starfall,if=buff.starweavers_warp.react|buff.touch_the_cosmos.react&talent.starweaver&buff.ascendant_stars.down","Spenders" );
ec_st->add_action( "starsurge,if=astral_power>80|!variable.eclipse_down|buff.starweavers_weft.react|buff.touch_the_cosmos.react&buff.ascendant_stars.up" );
ec_st->add_action( "fury_of_elune","Fury of Elune" );
ec_st->add_action( "force_of_nature","Builders" );
ec_st->add_action( "new_moon,if=astral_power.deficit>energize_amount" );
ec_st->add_action( "half_moon,if=astral_power.deficit>energize_amount" );
ec_st->add_action( "full_moon,if=astral_power.deficit>energize_amount" );
ec_st->add_action( "wild_mushroom,if=buff.eclipse_solar.up|cooldown.wild_mushroom.full_recharge_time<cooldown.ca_inc.remains" );
ec_st->add_action( "starfire,if=!variable.eclipse_down" );
ec_st->add_action( "wrath,if=variable.eclipse_down" );

kotg_st->add_action( "celestial_alignment,if=prev_gcd.1.force_of_nature|fight_remains<20","Cooldowns" );
kotg_st->add_action( "moonfire,target_if=remains<2|refreshable&variable.eclipse_down","Dots" );
kotg_st->add_action( "sunfire,target_if=remains<2|refreshable&variable.eclipse_down" );
kotg_st->add_action( "fury_of_elune,if=variable.opener&!variable.eclipse_down&buff.ascendant_stars.down|!variable.opener&(buff.harmony_of_the_grove.up|cooldown.force_of_nature.remains<gcd.max|talent.radiant_moonlight&cooldown.force_of_nature.remains>20)","Fury of Elune" );
kotg_st->add_action( "solar_eclipse,if=variable.opener&cooldown.eclipse.charges_fractional=2|!variable.opener&cooldown.solar_eclipse.charges_fractional>1.5&variable.cd_window|cooldown.solar_eclipse.ready&variable.cd_window_narrow|fight_remains<15","Enter Eclipse" );
kotg_st->add_action( "convoke_the_spirits,if=buff.ca_inc.up&astral_power<40|cooldown.ca_inc.remains>50&buff.harmony_of_the_grove.up&buff.ca_inc.down","Convoke" );
kotg_st->add_action( "wrath,if=!talent.convoke_the_spirits&buff.ascendant_stars.down&(variable.opener&astral_power<50|!variable.opener&astral_power<80&variable.no_weaver_procs&cooldown.force_of_nature.remains<15)","Cast Wrath if Going Solar" );
kotg_st->add_action( "sunfire,target_if=variable.opener&buff.ascendant_stars.down|!variable.opener&dot.sunfire.remains<10&variable.ca_soon&cooldown.force_of_nature.remains<3,line_cd=10","Cast Sunfire Before Cooldowns" );
kotg_st->add_action( "force_of_nature,if=!variable.opener|buff.ascendant_stars.down","Treants" );
kotg_st->add_action( "starfall,if=buff.starweavers_warp.react|buff.touch_the_cosmos.react&talent.starweaver&buff.ascendant_stars.down","Spenders" );
