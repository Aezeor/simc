ec_st->add_action( "celestial_alignment,if=buff.ca_inc.down&buff.ascendant_stars.down&(cooldown.convoke_the_spirits.remains<5&talent.convoke_the_spirits|cooldown.eclipse.charges_fractional<1.5&!talent.convoke_the_spirits|!talent.elunes_guidance&talent.convoke_the_spirits)","removed the eclipse charges check for convoke" );
