
# This default action priority list is automatically created based on your character.
# It is a attempt to provide you with a action list that is both simple and practicable,
# while resulting in a meaningful and good simulation. It may not result in the absolutely highest possible dps.
# Feel free to edit, adapt and improve it to your own needs.
# SimulationCraft is always looking for updates and improvements to the default action lists.

# Executed before combat begins. Accepts non-harmful actions only.
actions.precombat=snapshot_stats
actions.precombat+=/summon_pet,if=talent.unbreakable_bond
actions.precombat+=/use_item,name=algethar_puzzle_box
actions.precombat+=/aimed_shot,if=active_enemies<3|talent.black_arrow&talent.headshot
actions.precombat+=/steady_shot

# Executed every time the actor is available.
actions=variable,name=trueshot_ready,value=!talent.bullseye|fight_remains>cooldown.trueshot.duration+10|buff.bullseye.stack=buff.bullseye.max_stack|fight_remains<25
actions+=/auto_shot
actions+=/call_action_list,name=cds
actions+=/call_action_list,name=trinkets
actions+=/call_action_list,name=draoe,if=active_enemies>2&talent.trick_shots&hero_tree.dark_ranger
actions+=/call_action_list,name=sentaoe,if=active_enemies>2&talent.trick_shots&hero_tree.sentinel
actions+=/call_action_list,name=drst,if=hero_tree.dark_ranger
actions+=/call_action_list,name=sentst,if=hero_tree.sentinel

actions.cds=invoke_external_buff,name=power_infusion,if=buff.trueshot.remains>12|fight_remains<13
actions.cds+=/berserking,if=buff.trueshot.up|fight_remains<13
actions.cds+=/blood_fury,if=buff.trueshot.up|cooldown.trueshot.remains>30|fight_remains<16
actions.cds+=/ancestral_call,if=buff.trueshot.up|cooldown.trueshot.remains>30|fight_remains<16
actions.cds+=/fireblood,if=buff.trueshot.up|cooldown.trueshot.remains>30|fight_remains<9
actions.cds+=/lights_judgment,if=buff.trueshot.down
actions.cds+=/potion,if=buff.trueshot.up&(buff.bloodlust.up|target.health.pct<20)|fight_remains<31

actions.draoe=black_arrow,target_if=1+!dot.black_arrow.ticking
actions.draoe+=/trueshot,if=!buff.double_tap.up&(fight_remains>120|target.health.pct<20|fight_remains<20)
actions.draoe+=/rapid_fire,if=talent.unload.enabled&((buff.precise_shots.up&talent.no_scope.disabled)&buff.bulletstorm.stack<10|target.health.pct<20)
actions.draoe+=/multishot,if=buff.precise_shots.up&!talent.aspect_of_the_hydra.enabled|buff.trick_shots.down
actions.draoe+=/rapid_fire,if=buff.bulletstorm.remains<action.aimed_shot.execute_time
actions.draoe+=/trueshot,if=!buff.double_tap.up
actions.draoe+=/volley,if=!buff.double_tap.up
actions.draoe+=/aimed_shot
actions.draoe+=/wailing_arrow
actions.draoe+=/rapid_fire
actions.draoe+=/steady_shot

actions.drst=black_arrow,target_if=1+!dot.black_arrow.ticking
actions.drst+=/trueshot,if=!buff.double_tap.up&(fight_remains>120|target.health.pct<20|fight_remains<20)
actions.drst+=/rapid_fire,if=talent.unload.enabled&((buff.precise_shots.up&talent.no_scope.disabled)&buff.bulletstorm.stack<10|target.health.pct<20)
actions.drst+=/multishot,if=active_enemies>1&buff.precise_shots.up&!talent.aspect_of_the_hydra.enabled|buff.trick_shots.down&active_enemies>2&talent.trick_shots.enabled
actions.drst+=/arcane_shot,if=buff.precise_shots.up
actions.drst+=/rapid_fire,if=buff.bulletstorm.remains<action.aimed_shot.execute_time
actions.drst+=/trueshot,if=!buff.double_tap.up
actions.drst+=/volley,if=!buff.double_tap.up
actions.drst+=/aimed_shot
actions.drst+=/wailing_arrow
actions.drst+=/rapid_fire
actions.drst+=/steady_shot

actions.sentaoe=trueshot,if=!buff.double_tap.up&(fight_remains>100-30*talent.calling_the_shots.enabled|target.health.pct<20|fight_remains<20)&talent.bullseye.enabled
actions.sentaoe+=/rapid_fire,if=talent.unload.enabled&((buff.precise_shots.up&talent.no_scope.disabled)&buff.bulletstorm.stack<10|target.health.pct<20)
actions.sentaoe+=/multishot,target_if=1+debuff.sentinels_mark.down,if=buff.precise_shots.up&!talent.aspect_of_the_hydra.enabled|buff.trick_shots.down
actions.sentaoe+=/rapid_fire,if=buff.bulletstorm.remains<action.aimed_shot.execute_time
actions.sentaoe+=/trueshot,target_if=1+debuff.sentinels_mark.down,if=!buff.double_tap.up&!talent.bullseye.enabled
actions.sentaoe+=/volley,if=!buff.double_tap.up
actions.sentaoe+=/aimed_shot,target_if=1+debuff.sentinels_mark.remains
actions.sentaoe+=/moonlight_chakram
actions.sentaoe+=/rapid_fire
actions.sentaoe+=/steady_shot

actions.sentst=volley,if=!buff.double_tap.up&active_enemies=1&buff.bulletstorm.stack<11
actions.sentst+=/trueshot,if=!buff.double_tap.up&(fight_remains>100-30*talent.calling_the_shots.enabled|target.health.pct<20|fight_remains<20)&talent.bullseye.enabled
actions.sentst+=/rapid_fire,if=talent.unload.enabled&((buff.precise_shots.up&talent.no_scope.disabled)&buff.bulletstorm.stack<10|target.health.pct<20)
actions.sentst+=/arcane_shot,target_if=1+debuff.sentinels_mark.down,if=buff.precise_shots.up
actions.sentst+=/rapid_fire,if=buff.bulletstorm.remains<action.aimed_shot.execute_time
actions.sentst+=/trueshot,target_if=1+debuff.sentinels_mark.down,if=!buff.double_tap.up&!talent.bullseye.enabled
actions.sentst+=/volley,if=!buff.double_tap.up
actions.sentst+=/aimed_shot,target_if=1+debuff.sentinels_mark.remains
actions.sentst+=/moonlight_chakram
actions.sentst+=/rapid_fire
actions.sentst+=/steady_shot

actions.trinkets=use_items,slots=trinket1:trinket2,if=cooldown.trueshot.remains<2|!this_trinket.has_use_buff|buff.trueshot.remains>17|cooldown.trueshot.remains>45
actions.trinkets+=/use_item,name=algethar_puzzle_box,if=cooldown.trueshot.remains<2|fight_remains<23
